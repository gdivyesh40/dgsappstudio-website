---
/** Polymorphic button: renders <a> when `href` is set, else <button>. */
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  class?: string;
  disabled?: boolean;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  disabled = false,
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-full font-medium transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg)] disabled:opacity-50 disabled:pointer-events-none';

const variants = {
  primary:
    'bg-gradient-to-br from-brand-500 to-brand-600 text-white shadow-soft hover:shadow-glow hover:-translate-y-0.5',
  secondary:
    'bg-[var(--surface-2)] text-[var(--text)] border border-app hover:border-brand-500/50 hover:-translate-y-0.5',
  ghost: 'text-[var(--text)] hover:bg-[var(--surface-2)]',
};

const sizes = {
  sm: 'text-sm px-4 py-2',
  md: 'text-sm px-5 py-2.5',
  lg: 'text-base px-6 py-3',
};

const cls = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
const Tag = href ? 'a' : 'button';
---

<Tag
  class={cls}
  {...href ? { href } : { type, disabled }}
  {...rest}
>
  <slot />
</Tag>
