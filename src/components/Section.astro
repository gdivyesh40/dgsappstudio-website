---
/** Vertical section wrapper with optional heading block. */
interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  align?: 'left' | 'center';
  id?: string;
  class?: string;
  surface?: boolean;
}
const {
  eyebrow,
  title,
  subtitle,
  align = 'center',
  id,
  class: className = '',
  surface = false,
} = Astro.props;
const hasHeader = eyebrow || title || subtitle;
---

<section id={id} class:list={['py-16 sm:py-20 lg:py-24', surface && 'bg-app-surface', className]}>
  <div class="container-page">
    {
      hasHeader && (
        <div
          class:list={[
            'reveal mb-12 max-w-2xl',
            align === 'center' ? 'mx-auto text-center' : '',
          ]}
        >
          {eyebrow && (
            <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-brand">
              {eyebrow}
            </p>
          )}
          {title && (
            <h2 class="text-balance text-3xl font-bold tracking-tight sm:text-4xl">
              {title}
            </h2>
          )}
          {subtitle && (
            <p class="mt-4 text-pretty text-lg text-muted">{subtitle}</p>
          )}
        </div>
      )
    }
    <slot />
  </div>
</section>
