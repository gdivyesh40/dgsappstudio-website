---
/** Wordmark + icon lockup for the studio. */
interface Props {
  href?: string;
  compact?: boolean;
  class?: string;
}
const { href = '/', compact = false, class: className = '' } = Astro.props;
---

<a
  href={href}
  class={`group inline-flex items-center gap-2.5 ${className}`}
  aria-label="DGS App Studio — home"
>
  <span
    class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-600 shadow-soft transition-transform duration-300 group-hover:scale-105"
  >
    <svg viewBox="0 0 64 64" class="h-5 w-5" aria-hidden="true">
      <path
        d="M20 18h9c8.3 0 14 5.7 14 14s-5.7 14-14 14h-9V18zm8 22c4.7 0 8-3.3 8-8s-3.3-8-8-8h-1v16h1z"
        fill="#fff"></path>
    </svg>
  </span>
  {
    !compact && (
      <span class="text-[15px] font-semibold tracking-tight">
        DGS <span class="text-muted font-medium">App Studio</span>
      </span>
    )
  }
</a>
