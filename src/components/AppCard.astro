---
import type { AppEntry } from '../lib/apps';
import { STATUS_LABEL, appPath, primaryCategory } from '../lib/apps';
import AppIcon from './AppIcon.astro';

interface Props {
  app: AppEntry;
}
const { app } = Astro.props;
const { data } = app;
const href = appPath(app);
---

<article
  class="reveal surface-card group relative flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-soft-lg"
>
  <div class="p-6">
    <div class="flex items-start justify-between gap-4">
      <AppIcon app={data} class="h-14 w-14 rounded-2xl shadow-soft" iconClass="h-7 w-7 text-white" pixels={56} />
      <span
        class:list={[
          'rounded-full px-3 py-1 text-xs font-medium',
          data.status === 'live'
            ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400'
            : 'bg-brand-500/10 text-brand',
        ]}
      >
        {STATUS_LABEL[data.status]}
      </span>
    </div>

    <h3 class="mt-5 text-lg font-semibold">
      <a href={href} class="after:absolute after:inset-0">{data.title}</a>
    </h3>
    <p class="mt-1 text-xs font-medium uppercase tracking-wide text-muted">
      {primaryCategory(app)}
    </p>
    <p class="mt-3 text-sm leading-relaxed text-muted">{data.description}</p>

    <ul class="mt-5 space-y-2">
      {
        data.highlights.slice(0, 3).map((h) => (
          <li class="flex items-start gap-2 text-sm text-muted">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {h}
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mt-auto flex items-center gap-3 border-t border-app p-6">
    <a
      href={href}
      class="relative z-10 text-sm font-medium text-brand transition-colors hover:text-brand-700 dark:text-brand-400"
    >
      View Details →
    </a>
    <span class="ml-auto">
      {
        data.playStoreUrl ? (
          <a
            href={data.playStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-10 inline-flex items-center gap-1.5 rounded-full bg-[var(--surface-2)] px-3 py-1.5 text-xs font-medium"
          >
            Google Play
          </a>
        ) : (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--surface-2)] px-3 py-1.5 text-xs font-medium text-muted">
            Play Store soon
          </span>
        )
      }
    </span>
  </div>
</article>
