---
import Logo from './Logo.astro';
import { FOOTER_NAV } from '../data/navigation';
import { SITE, SOCIAL, CONTACT } from '../consts';

const year = new Date().getFullYear();

const socials = [
  {
    label: 'GitHub',
    href: SOCIAL.github,
    path: 'M12 2a10 10 0 00-3.2 19.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.6-1.4-2.2-.3-4.5-1.1-4.5-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 015 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.5 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5A10 10 0 0012 2z',
  },
  {
    label: 'X',
    href: SOCIAL.x,
    path: 'M18.9 2H22l-7.1 8.1L23.2 22h-6.6l-5.2-6.8L5.5 22H2.4l7.6-8.7L1.2 2h6.8l4.7 6.2L18.9 2zm-1.2 18h1.8L7.1 3.9H5.2L17.7 20z',
  },
  {
    label: 'LinkedIn',
    href: SOCIAL.linkedin,
    path: 'M6.9 8.5v11H3.6v-11h3.3zM5.2 3.5a1.9 1.9 0 110 3.8 1.9 1.9 0 010-3.8zM20.4 19.5h-3.3v-5.9c0-1.5-.6-2.4-1.8-2.4-1 0-1.5.7-1.8 1.3-.1.2-.1.6-.1.9v6.1H10s.1-9.9 0-11h3.3v1.6c.4-.7 1.2-1.7 3-1.7 2.2 0 3.9 1.4 3.9 4.5v6.5z',
  },
];
---

<footer class="mt-24 border-t border-app bg-app-surface">
  <div class="container-page py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div class="max-w-xs">
        <Logo />
        <p class="mt-4 text-sm text-muted">
          {SITE.description}
        </p>
        <div class="mt-5 flex gap-2">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="grid h-9 w-9 place-items-center rounded-full border border-app text-muted transition-colors hover:border-brand-500/50 hover:text-brand"
              >
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={s.path} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      {
        FOOTER_NAV.map((col) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-muted">
              {col.title}
            </h3>
            <ul class="mt-4 space-y-3">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-sm text-muted transition-colors hover:text-brand"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-app pt-6 text-sm text-muted sm:flex-row sm:items-center"
    >
      <p>© {year} {SITE.name}. All rights reserved.</p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href={`mailto:${CONTACT.general}`} class="hover:text-brand">{CONTACT.general}</a>
        <a href="/privacy" class="hover:text-brand">Privacy</a>
        <a href="/terms" class="hover:text-brand">Terms</a>
      </div>
    </div>
  </div>
</footer>
