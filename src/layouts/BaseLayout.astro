---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, SOCIAL, CONTACT } from '../consts';
// Self-hosted Inter variable font — weight axis only (no italic/optical-size
// variants, which we never use). Vite fingerprints + emits the woff2 files, and
// unicode-range subsetting means browsers only download the latin glyphs needed.
import '@fontsource-variable/inter/wght.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  /** Page-specific structured data, appended to the global Organization/WebSite. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, image, imageAlt, type, noindex, jsonLd } = Astro.props;

// Global structured data present on every page.
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  foundingDate: String(SITE.founded),
  logo: `${SITE.url}/favicon.svg`,
  email: CONTACT.general,
  sameAs: [SOCIAL.github, SOCIAL.x, SOCIAL.linkedin],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'en',
};

// Merge global + optional page-specific structured data into one list.
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [orgJsonLd, websiteJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      noindex={noindex}
      jsonLd={allJsonLd}
    />
    <!-- Mark JS as available (gates scroll-reveal) and apply the saved theme
         before paint to avoid a flash of the wrong theme or empty content. -->
    <script is:inline>
      (function () {
        var el = document.documentElement;
        el.classList.add('js');
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            el.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-brand-600 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" tabindex="-1" class="focus:outline-none">
      <slot />
    </main>
    <Footer />

    <!-- Reveal-on-scroll for elements with the .reveal class. -->
    <script is:inline>
      (function () {
        const els = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window) || !els.length) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
