---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  updated: string;
  intro?: string;
  /** Table-of-contents entries: { id, label } matching section headings. */
  toc?: { id: string; label: string }[];
}
const { title, description, updated, intro, toc = [] } = Astro.props;
---

<BaseLayout title={title} description={description} type="article">
  <div class="border-b border-app bg-app-surface">
    <div class="container-page py-14 sm:py-16">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand">
        Legal
      </p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
      {intro && <p class="mt-4 max-w-2xl text-lg text-muted">{intro}</p>}
      <p class="mt-4 text-sm text-muted">Last updated: {updated}</p>
    </div>
  </div>

  <div class="container-page py-12 sm:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_1fr]">
      {
        toc.length > 0 && (
          <aside class="hidden lg:block">
            <nav class="sticky top-24" aria-label="On this page">
              <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted">
                On this page
              </p>
              <ul class="space-y-2 border-l border-app">
                {toc.map((t) => (
                  <li>
                    <a
                      href={`#${t.id}`}
                      class="-ml-px block border-l-2 border-transparent py-1 pl-4 text-sm text-muted transition-colors hover:border-brand-500 hover:text-brand-600"
                    >
                      {t.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )
      }

      <article class="prose-legal max-w-none">
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>
